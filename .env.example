# Development — local Express backend
VITE_API_URL=http://localhost:3001/api

# Production — api.aiistech.com served through Multiplic/Nginx
# VITE_API_URL=https://api.aiistech.com/api

# Multiplic backend secrets (set on the production server, never commit)
# JWT_SECRET=<generate with: openssl rand -hex 32>
# JWT_REFRESH_SECRET=<generate with: openssl rand -hex 32>
# SYNC_SECRET=<generate with: openssl rand -hex 32>
# MULTIPLIC_HOST=<your VPS hostname or IP>
# DNS_PROVIDER=cloudflare
